# ── APIs ────────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# OpenAI : requis si le provider TTS « openai » est sélectionné (page /admin.html)
OPENAI_API_KEY=your_openai_api_key_here

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Bridge ───────────────────────────────────────────────────────────────────
PORT=3001
BRIDGE_URL=http://localhost:3001
# Token d'authentification pour /speak. Si défini, n8n doit envoyer
# l'en-tête `Authorization: Bearer <ce_token>`. Laisser vide = endpoint ouvert.
BRIDGE_TOKEN=

# ── ElevenLabs Voice IDs (récupérer sur votre compte ElevenLabs) ─────────────
VOICE_MC=your_mc_voice_id
VOICE_STRATEGE=your_stratege_voice_id
VOICE_CREATIF=your_creatif_voice_id
VOICE_CRITIQUE=your_critique_voice_id

# ── Voix OpenAI par rôle (optionnel — défauts: onyx/echo/nova/fable) ─────────
# Voix dispo : alloy, ash, ballad, coral, echo, fable, nova, onyx, sage, shimmer, verse
VOICE_OPENAI_MC=onyx
VOICE_OPENAI_STRATEGE=echo
VOICE_OPENAI_CREATIF=nova
VOICE_OPENAI_CRITIQUE=fable

# ── TTS : provider/modèle par défaut (modifiables à chaud via /admin.html) ──
# Le provider par défaut est « openai ». La config est persistée dans Redis.
# ELEVENLABS_MODEL=eleven_flash_v2_5
# skipTts=true   # démarre avec l'audio désactivé
